@inherits VctoonLayoutComponentBase
@inject ICurrentUser CurrentUser
@inject ILoginService LoginService
@inject UserStore UserStore
@attribute [Authorize]
<div class="mt-2 mx-2">
    <LayoutErrorBoundary>

        <FluentLayout>
            <FluentHeader class="rounded-2 z-20">
                <HeaderContent></HeaderContent>

            </FluentHeader>

            <FluentStack Orientation="Orientation.Horizontal" Class="mt-2" style="height: calc(100dvh - 65.8px);">
                <NavMenu></NavMenu>

                <FluentBodyContent class="h-full w-full max-h-full">
                    <LayoutContentErrorBoundary>
                        @Body
                    </LayoutContentErrorBoundary>
                </FluentBodyContent>
                <FluentDialogProvider/>
                <FluentToastProvider/>
                <FluentTooltipProvider/>
                <FluentMessageBarProvider Section="AppFluentMessageBarProvider"/>
            </FluentStack>


        </FluentLayout>
    </LayoutErrorBoundary>


    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
</div>

