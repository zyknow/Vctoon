@using System.ComponentModel
@using Microsoft.AspNetCore.Components.Authorization
@using Vctoon.Blazor.Client.Components.Themes
@using Vctoon.Blazor.Client.Hubs
@using Vctoon.Localization.Vctoon
@using Volo.Abp.Users
@inherits VctoonLayoutComponentBase
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ICurrentUser CurrentUser
@inject AppStore AppStore
@inject IToastService ToastService
@inject IStringLocalizer<VctoonResource> L
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject LibraryScanHub LibraryScanHub
@inject IMessageService MessageService
@inject  UserStore UserStore
<div class="mt-2 mx-2">
    <FluentLayout>
        <FluentHeader class="rounded-2">
            <div class="flex flex-row items-center space-x-4 ">
                <FluentButton IconStart="@(new Icons.Regular.Size28.List())"
                              BackgroundColor="transparent"
                              Appearance="Appearance.Accent"
                              OnClick="@SwitchMenuBar">
                </FluentButton>
                <span class="text-3xl select-none mb-1.3">Vctoon</span>
            </div>
            
            <FluentSpacer/>
            
            <div class="flex flex-row space-x-5 items-center select-none">
                
                <FluentIcon Value="@(new Icons.Regular.Size24.Alert())" Color="Color.Lightweight">
                </FluentIcon>
                
                <div class="cursor-pointer flex items-center relative" onclick="@OpenThemeSettingPanel" @onclick:stopPropagation>
                    
                    @if (_backgroundRunning)
                    {
                        <div class="animate-spin absolute flex items-center">
                            <FluentIcon class="scale-150" Color="Color.Warning"
                                        Value="@(new Icons.Regular.Size24.CircleHintHalfVertical())" Slot="start">
                            </FluentIcon>
                        </div>
                    }
                    
                    
                    <FluentIcon Color="@(_backgroundRunning ? Color.Warning : Color.Lightweight)"
                                Value="@(backgroundRunningIcons[_backgroundRunning])" Slot="start">
                        
                    </FluentIcon>
                </div>
                
                
                <FluentIcon Color="Color.Lightweight" Value="@(new Icons.Regular.Size24.Settings())"
                            OnClick="@OpenThemeSettingPanel">
                </FluentIcon>
                
                
                <FluentTooltip Anchor="settingIcon">
                    Theme Settings
                </FluentTooltip>
                
                <LanguageSelector/>
                
                <FluentProfileMenu Status="@PresenceStatus.Available"
                                   HeaderLabel="Vctoon"
                                   Initials="@CurrentUser.Name?.FirstOrDefault().ToString()"
                                   FullName="@CurrentUser.Name"
                                   EMail="@CurrentUser.Email"
                                   Style="min-width: 330px;"
                                   OnHeaderButtonClick="@(() => { // TODO: sign out
                                                        })"/>
            </div>
        </FluentHeader>
        
        <FluentStack Orientation="Orientation.Horizontal" Class="mt-2" style="height: calc(100dvh - 65.8px);">
            <NavMenu Expanded="@NavMenuExpanded"></NavMenu>
            
            <FluentBodyContent class="h-full w-full max-h-full overflow-y-auto">
                @Body
            </FluentBodyContent>
            <FluentToastProvider/>
            <FluentDialogProvider/>
            <FluentTooltipProvider/>
            <FluentMessageBarProvider Section="AppFluentMessageBarProvider"/>
        </FluentStack>
        
    </FluentLayout>
    
    
    <div id="blazor-error-ui">
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
</div>

@code
{
    public DesignThemeModes ThemeMode { get; set; } = DesignThemeModes.System;
    
    
    public OfficeColor? ThemeOfficeColor { get; set; }
    
    public bool NavMenuExpanded { get; set; } = true;
    
    bool _backgroundRunning;
    
    Dictionary<bool, Icon> backgroundRunningIcons = new()
    {
        {false, new Icons.Regular.Size24.Flash()},
        {true, new Icons.Regular.Size24.FlashSparkle()}
    };
    
    
    async Task OpenThemeSettingPanel()
    {
        var themeConfig = new ThemeSettingPanelContent(ThemeMode, ThemeOfficeColor);
        
        themeConfig.PropertyChanged += ThemeConfigOnPropertyChanged;
        
        DialogParameters<ThemeSettingPanelContent> parameters = new()
        {
            Title = $"Theme Settings",
            Alignment = HorizontalAlignment.Right,
            Content = themeConfig,
            PrimaryActionEnabled = false
        };
        await DialogService.ShowPanelAsync<ThemeSettingPanel>(themeConfig, parameters);
    }
    
    private void ThemeConfigOnPropertyChanged(object? sender, PropertyChangedEventArgs e)
    {
        var config = sender as ThemeSettingPanelContent;
        if (config == null)
        {
            return;
        }
        
        ThemeMode = config.ThemeMode;
        ThemeOfficeColor = config.ThemeColor;
        StateHasChanged();
    }
    
    async Task SwitchMenuBar()
    {
        NavMenuExpanded = !NavMenuExpanded;
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var isAuthenticated = user.Identity.IsAuthenticated;
            
            if (isAuthenticated)
            {
                await LibraryScanHub.StartAsync();
                
                LibraryScanHub.OnScanning += async (msg) =>
                {
                    _backgroundRunning = true;
                    
                    await InvokeAsync(StateHasChanged);
                };
                
                LibraryScanHub.OnScanned += async (libraryId) =>
                {
                    _backgroundRunning = false;
                    
                    await InvokeAsync(() =>
                    {
// MessageService.ShowMessageBar(options =>
// {
//     options.Intent = MessageIntent.Success;
//     options.Title = L["LibraryScanCompleted"];
//     options.Body = L["LibraryScanCompletedMessage", UserStore.Libraries.FirstOrDefault(x => x.Id == libraryId)?.Name ?? libraryId.ToString()];
//     options.Timestamp = DateTime.Now;
//     options.Section = "AppFluentMessageBarProvider";
// });
                        
                        StateHasChanged();
                    });
                };
            }
        }
        
        await base.OnAfterRenderAsync(firstRender);
    }
    
}